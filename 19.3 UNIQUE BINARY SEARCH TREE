class Solution:
    def __init__(self):
        self.res = []
    def generateTrees(self, n: int) -> List[Optional[TreeNode]]:
        if n == 0:
            return self.res        
        def buildTrees(start: int, end: int) -> List[Optional[TreeNode]]:
            if start > end:
                return [None]            
            subtrees = []
            for i in range(start, end + 1):
                left_trees = buildTrees(start, i - 1)
                right_trees = buildTrees(i + 1, end)                
                for left in left_trees:
                    for right in right_trees:
                        root_node = TreeNode(i)
                        root_node.left = left
                        root_node.right = right
                        subtrees.append(root_node)
            return subtrees
        self.res = buildTrees(1, n)
        return self.res
